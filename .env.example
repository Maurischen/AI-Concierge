OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_WEB_MODEL=gpt-5.4-mini
ENABLE_WEB_COMPATIBILITY=true
SALES_EMAIL=sales@example.com
SUPPORT_EMAIL=support@example.com
ADMIN_TOKEN=change-this-admin-token
PORT=5174
SHOPIFY_API_VERSION=2026-01
SHOPIFY_SCOPES=read_products,read_inventory,read_locations,read_files
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_APP_URL=https://your-render-url.onrender.com
DEFAULT_SHOP_DOMAIN=demo
PREFERRED_BRANDS_JSON={"cable":["UGreen"],"hub":["UGreen"],"adapter":["UGreen"],"bag":["Port Designs"]}

# Optional fallback for one-off local syncs. For production multi-shop usage,
# register each shop with npm run register:shop instead.
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
